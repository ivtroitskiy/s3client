
#Область ПрограммныйИнтерфейс

// Создает параметры подключения к S3-совместимому хранилищу.
//
// Endpoint - адрес сервиса без имени bucket, например http://localhost:9000.
// Region - регион подписи AWS Signature V4. Для MinIO обычно us-east-1.
// Bucket - имя bucket.
// AccessKeyId - идентификатор ключа доступа.
// SecretAccessKey - секретный ключ доступа.
// PathStyle - Истина для адреса вида endpoint/bucket/key.
// UseSSL - Ложь для HTTP; Истина или Неопределено для HTTPS, если схема не задана в Endpoint.
// Таймаут - таймаут HTTP-соединения в секундах.
// Возвращаемое значение:
//   Структура - параметры подключения.
Функция ПараметрыПодключения(Endpoint, Region, Bucket, AccessKeyId, SecretAccessKey,
		PathStyle = Истина, UseSSL = Неопределено, Таймаут = 30) Экспорт
	
	Параметры = Новый Структура;
	Параметры.Вставить("Endpoint", СокрЛП(Endpoint));
	Параметры.Вставить("Region", СокрЛП(Region));
	Параметры.Вставить("Bucket", СокрЛП(Bucket));
	Параметры.Вставить("AccessKeyId", AccessKeyId);
	Параметры.Вставить("SecretAccessKey", SecretAccessKey);
	Параметры.Вставить("PathStyle", PathStyle);
	Параметры.Вставить("UseSSL", UseSSL);
	Параметры.Вставить("Таймаут", Таймаут);
	
	Возврат Параметры;
	
КонецФункции

// Загружает двоичные данные в объект S3 через PUT Object.
//
// ПараметрыПодключения - Структура - параметры, созданные функцией ПараметрыПодключения.
// КлючОбъекта - Строка - ключ объекта внутри bucket.
// ДвоичныеДанные - ДвоичныеДанные - тело объекта.
// ТипСодержимого - Строка - Content-Type; если пустой, определяется по расширению ключа.
// Возвращаемое значение:
//   Структура - код состояния и заголовки HTTP-ответа.
Функция ЗагрузитьДвоичныеДанные(ПараметрыПодключения, КлючОбъекта, ДвоичныеДанные,
		ТипСодержимого = "") Экспорт
	
	ПроверитьПараметрыПодключения(ПараметрыПодключения);
	
	Если Не ТипЗнч(ДвоичныеДанные) = Тип("ДвоичныеДанные") Тогда
		ВызватьИсключение "S3: параметр ДвоичныеДанные должен иметь тип ДвоичныеДанные.";
	КонецЕсли;
	
	ПараметрыЗапроса = ПодготовитьПараметрыЗапроса(ПараметрыПодключения, КлючОбъекта);
	Заголовки = БазовыеЗаголовки(
		ПараметрыЗапроса,
		ДвоичныеДанные,
		ТипСодержимогоДляЗагрузки(КлючОбъекта, ТипСодержимого));
	
	ПодписатьЗапрос(ПараметрыПодключения, "PUT", ПараметрыЗапроса.КаноническийURI, "", Заголовки, ДвоичныеДанные);
	
	Запрос = Новый HTTPЗапрос(ПараметрыЗапроса.ПутьЗапроса);
	Запрос.Заголовки = Заголовки;
	Запрос.УстановитьТелоИзДвоичныхДанных(ДвоичныеДанные);
	
	Ответ = СоединениеS3(ПараметрыЗапроса, ПараметрыПодключения).ВызватьHTTPМетод("PUT", Запрос);
	ПроверитьОтвет(Ответ, "загрузки объекта", 200);
	
	Результат = Новый Структура;
	Результат.Вставить("КодСостояния", Ответ.КодСостояния);
	Результат.Вставить("Заголовки", Ответ.Заголовки);
	Возврат Результат;
	
КонецФункции

// Читает объект S3 через GET Object и возвращает ДвоичныеДанные.
//
// ПараметрыПодключения - Структура - параметры подключения.
// КлючОбъекта - Строка - ключ объекта внутри bucket.
// Возвращаемое значение:
//   ДвоичныеДанные - тело объекта.
Функция ПрочитатьДвоичныеДанные(ПараметрыПодключения, КлючОбъекта) Экспорт
	
	ПроверитьПараметрыПодключения(ПараметрыПодключения);
	
	ПустоеТело = СтрокаВДвоичныеДанные("");
	ПараметрыЗапроса = ПодготовитьПараметрыЗапроса(ПараметрыПодключения, КлючОбъекта);
	Заголовки = БазовыеЗаголовки(ПараметрыЗапроса, ПустоеТело);
	
	ПодписатьЗапрос(ПараметрыПодключения, "GET", ПараметрыЗапроса.КаноническийURI, "", Заголовки, ПустоеТело);
	
	Запрос = Новый HTTPЗапрос(ПараметрыЗапроса.ПутьЗапроса);
	Запрос.Заголовки = Заголовки;
	
	Ответ = СоединениеS3(ПараметрыЗапроса, ПараметрыПодключения).ВызватьHTTPМетод("GET", Запрос);
	ПроверитьОтвет(Ответ, "чтения объекта", 200);
	
	Возврат Ответ.ПолучитьТелоКакДвоичныеДанные();
	
КонецФункции

// Удаляет объект S3 через DELETE Object.
//
// ПараметрыПодключения - Структура - параметры подключения.
// КлючОбъекта - Строка - ключ объекта внутри bucket.
// Возвращаемое значение:
//   Структура - код состояния и заголовки HTTP-ответа.
Функция УдалитьОбъект(ПараметрыПодключения, КлючОбъекта) Экспорт
	
	ПроверитьПараметрыПодключения(ПараметрыПодключения);
	
	ПустоеТело = СтрокаВДвоичныеДанные("");
	ПараметрыЗапроса = ПодготовитьПараметрыЗапроса(ПараметрыПодключения, КлючОбъекта);
	Заголовки = БазовыеЗаголовки(ПараметрыЗапроса, ПустоеТело);
	
	ПодписатьЗапрос(ПараметрыПодключения, "DELETE", ПараметрыЗапроса.КаноническийURI, "", Заголовки, ПустоеТело);
	
	Запрос = Новый HTTPЗапрос(ПараметрыЗапроса.ПутьЗапроса);
	Запрос.Заголовки = Заголовки;
	
	Ответ = СоединениеS3(ПараметрыЗапроса, ПараметрыПодключения).ВызватьHTTPМетод("DELETE", Запрос);
	ПроверитьОтвет(Ответ, "удаления объекта", 204);
	
	Результат = Новый Структура;
	Результат.Вставить("КодСостояния", Ответ.КодСостояния);
	Результат.Вставить("Заголовки", Ответ.Заголовки);
	Возврат Результат;
	
КонецФункции

// Удаляет список объектов S3 последовательными DELETE Object.
//
// ПараметрыПодключения - Структура - параметры подключения.
// КлючиОбъектов - Массив из Строка - ключи объектов для удаления.
// Возвращаемое значение:
//   Массив из Структура - результат удаления по каждому ключу.
Функция УдалитьСписокОбъектов(ПараметрыПодключения, КлючиОбъектов) Экспорт
	
	Результаты = Новый Массив;
	
	Для Каждого КлючОбъекта Из КлючиОбъектов Цикл
		РезультатУдаления = УдалитьОбъект(ПараметрыПодключения, КлючОбъекта);
		Результат = Новый Структура;
		Результат.Вставить("Ключ", КлючОбъекта);
		Результат.Вставить("КодСостояния", РезультатУдаления.КодСостояния);
		Результаты.Добавить(Результат);
	КонецЦикла;
	
	Возврат Результаты;
	
КонецФункции

// Проверяет существование объекта S3 через HEAD Object без чтения тела объекта.
//
// ПараметрыПодключения - Структура - параметры подключения.
// КлючОбъекта - Строка - ключ объекта внутри bucket.
// Возвращаемое значение:
//   Булево - Истина, если объект существует.
Функция ОбъектСуществует(ПараметрыПодключения, КлючОбъекта) Экспорт
	
	Возврат ПолучитьИнформациюОбОбъекте(ПараметрыПодключения, КлючОбъекта) <> Неопределено;
	
КонецФункции

// Возвращает техническую информацию S3-объекта через HEAD Object.
// Если объект не найден, возвращает Неопределено.
//
// ПараметрыПодключения - Структура - параметры подключения.
// КлючОбъекта - Строка - ключ объекта внутри bucket.
// Возвращаемое значение:
//   Структура, Неопределено - информация объекта или Неопределено, если объект не найден.
Функция ПолучитьИнформациюОбОбъекте(ПараметрыПодключения, КлючОбъекта) Экспорт
	
	ПроверитьПараметрыПодключения(ПараметрыПодключения);
	
	ПустоеТело = СтрокаВДвоичныеДанные("");
	ПараметрыЗапроса = ПодготовитьПараметрыЗапроса(ПараметрыПодключения, КлючОбъекта);
	Заголовки = БазовыеЗаголовки(ПараметрыЗапроса, ПустоеТело);
	
	ПодписатьЗапрос(ПараметрыПодключения, "HEAD", ПараметрыЗапроса.КаноническийURI, "", Заголовки, ПустоеТело);
	
	Запрос = Новый HTTPЗапрос(ПараметрыЗапроса.ПутьЗапроса);
	Запрос.Заголовки = Заголовки;
	
	Ответ = СоединениеS3(ПараметрыЗапроса, ПараметрыПодключения).ВызватьHTTPМетод("HEAD", Запрос);
	
	Если Ответ.КодСостояния = 200 Тогда
		Результат = Новый Структура;
		Результат.Вставить("КодСостояния", Ответ.КодСостояния);
		Результат.Вставить("Bucket", ПараметрыПодключения.Bucket);
		Результат.Вставить("Ключ", КлючОбъекта);
		Результат.Вставить("Заголовки", Ответ.Заголовки);
		Результат.Вставить("ТипСодержимого", ЗначениеЗаголовка(Ответ.Заголовки, "Content-Type"));
		Результат.Вставить("Размер", ЧислоИзСтроки(ЗначениеЗаголовка(Ответ.Заголовки, "Content-Length")));
		Результат.Вставить("ETag", ОчиститьETag(ЗначениеЗаголовка(Ответ.Заголовки, "ETag")));
		Результат.Вставить("ДатаИзменения", ЗначениеЗаголовка(Ответ.Заголовки, "Last-Modified"));
		Результат.Вставить("КлассХранения", ЗначениеЗаголовка(Ответ.Заголовки, "x-amz-storage-class"));
		Возврат Результат;
	ИначеЕсли Ответ.КодСостояния = 404 Тогда
		Возврат Неопределено;
	Иначе
		ПроверитьОтвет(Ответ, "получения информации об объекте", 200);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Получает список объектов bucket через ListObjectsV2.
//
// ПараметрыПодключения - Структура - параметры подключения.
// Префикс - Строка - фильтр ключей по префиксу.
// Максимум - Число - максимальное количество объектов в ответе.
// ТокенПродолжения - Строка - continuation-token для следующей страницы.
// Возвращаемое значение:
//   Структура - поля Объекты, ЕстьЕще, СледующийТокен.
Функция ПолучитьСписокОбъектов(ПараметрыПодключения, Префикс = "", Максимум = 1000,
		ТокенПродолжения = "") Экспорт
	
	ПроверитьПараметрыПодключения(ПараметрыПодключения);
	
	ПустоеТело = СтрокаВДвоичныеДанные("");
	ПараметрыЗапроса = ПодготовитьПараметрыЗапроса(ПараметрыПодключения);
	ПараметрыQuery = Новый Соответствие;
	ПараметрыQuery.Вставить("list-type", "2");
	ПараметрыQuery.Вставить("max-keys", Формат(Максимум, "ЧГ=0"));
	
	Если Не ПустаяСтрока(Префикс) Тогда
		ПараметрыQuery.Вставить("prefix", Префикс);
	КонецЕсли;
	
	Если Не ПустаяСтрока(ТокенПродолжения) Тогда
		ПараметрыQuery.Вставить("continuation-token", ТокенПродолжения);
	КонецЕсли;
	
	КаноническийQueryString = КаноническаяСтрокаЗапроса(ПараметрыQuery);
	Заголовки = БазовыеЗаголовки(ПараметрыЗапроса, ПустоеТело);
	ПодписатьЗапрос(
		ПараметрыПодключения,
		"GET",
		ПараметрыЗапроса.КаноническийURI,
		КаноническийQueryString,
		Заголовки,
		ПустоеТело);
	
	Запрос = Новый HTTPЗапрос(ПутьЗапросаСQuery(ПараметрыЗапроса.ПутьЗапроса, КаноническийQueryString));
	Запрос.Заголовки = Заголовки;
	
	Ответ = СоединениеS3(ПараметрыЗапроса, ПараметрыПодключения).ВызватьHTTPМетод("GET", Запрос);
	ПроверитьОтвет(Ответ, "получения списка объектов", 200);
	
	Возврат РазобратьОтветСпискаОбъектов(Ответ.ПолучитьТелоКакСтроку());
	
КонецФункции

// Возвращает presigned URL на чтение объекта через GET.
//
// ПараметрыПодключения - Структура - параметры подключения.
// КлючОбъекта - Строка - ключ объекта внутри bucket.
// СрокДействияСек - Число - срок действия ссылки в секундах, от 1 до 604800.
// Возвращаемое значение:
//   Строка - временная ссылка.
Функция ПолучитьВременнуюСсылкуНаЧтение(ПараметрыПодключения, КлючОбъекта,
		СрокДействияСек = 3600) Экспорт
	
	Возврат ПолучитьВременнуюСсылку(ПараметрыПодключения, "GET", КлючОбъекта, СрокДействияСек);
	
КонецФункции

// Возвращает presigned URL на запись объекта через PUT.
//
// ПараметрыПодключения - Структура - параметры подключения.
// КлючОбъекта - Строка - ключ объекта внутри bucket.
// СрокДействияСек - Число - срок действия ссылки в секундах, от 1 до 604800.
// Возвращаемое значение:
//   Строка - временная ссылка.
Функция ПолучитьВременнуюСсылкуНаЗапись(ПараметрыПодключения, КлючОбъекта,
		СрокДействияСек = 3600) Экспорт
	
	Возврат ПолучитьВременнуюСсылку(ПараметрыПодключения, "PUT", КлючОбъекта, СрокДействияСек);
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПроверитьПараметрыПодключения(ПараметрыПодключения)
	
	Если ПараметрыПодключения = Неопределено Тогда
		ВызватьИсключение "S3: параметры подключения не заданы.";
	КонецЕсли;
	
	ОбязательныеПоля = Новый Массив;
	ОбязательныеПоля.Добавить("Endpoint");
	ОбязательныеПоля.Добавить("Region");
	ОбязательныеПоля.Добавить("Bucket");
	ОбязательныеПоля.Добавить("AccessKeyId");
	ОбязательныеПоля.Добавить("SecretAccessKey");
	
	Для Каждого ИмяПоля Из ОбязательныеПоля Цикл
		ЗначениеПоля = Неопределено;
		Если Не ПараметрыПодключения.Свойство(ИмяПоля, ЗначениеПоля)
			Или ПустаяСтрока(ЗначениеПоля) Тогда
			ВызватьИсключение "S3: не заполнен параметр подключения " + ИмяПоля + ".";
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ПодготовитьПараметрыЗапроса(ПараметрыПодключения, КлючОбъекта = "")
	
	Endpoint = РазобратьEndpoint(ПараметрыПодключения.Endpoint, ПараметрыПодключения.UseSSL);
	PathStyle = ПолучитьСвойствоСПараметромПоУмолчанию(ПараметрыПодключения, "PathStyle", Истина);
	Bucket = ПараметрыПодключения.Bucket;
	
	Если PathStyle Тогда
		ХостСоединения = Endpoint.Хост;
		HostHeader = Endpoint.ХостСПортом;
		ПутьЗапроса = "/" + Bucket;
	Иначе
		ХостСоединения = Bucket + "." + Endpoint.Хост;
		HostHeader = ХостСоединения + ?(Endpoint.ПортВХосте, ":" + Формат(Endpoint.Порт, "ЧГ=0"), "");
		ПутьЗапроса = "/";
	КонецЕсли;
	
	Если Не ПустаяСтрока(КлючОбъекта) Тогда
		КаноническийКлюч = КодироватьПутьS3(КлючОбъекта);
		Если Прав(ПутьЗапроса, 1) = "/" Тогда
			ПутьЗапроса = ПутьЗапроса + КаноническийКлюч;
		Иначе
			ПутьЗапроса = ПутьЗапроса + "/" + КаноническийКлюч;
		КонецЕсли;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Схема", Endpoint.Схема);
	Результат.Вставить("Хост", ХостСоединения);
	Результат.Вставить("Порт", Endpoint.Порт);
	Результат.Вставить("ХостСПортом", HostHeader);
	Результат.Вставить("ПутьЗапроса", ПутьЗапроса);
	Результат.Вставить("КаноническийURI", ПутьЗапроса);
	Возврат Результат;
	
КонецФункции

Функция БазовыеЗаголовки(ПараметрыЗапроса, ТелоЗапроса, ТипСодержимого = "")
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("host", ПараметрыЗапроса.ХостСПортом);
	Заголовки.Вставить("x-amz-date", ДатаAWS(ТекущаяУниверсальнаяДата()));
	Заголовки.Вставить("x-amz-content-sha256", SHA256Hex(ТелоЗапроса));
	
	Если Не ПустаяСтрока(ТипСодержимого) Тогда
		Заголовки.Вставить("content-type", ТипСодержимого);
	КонецЕсли;
	
	Возврат Заголовки;
	
КонецФункции

Функция ТипСодержимогоДляЗагрузки(КлючОбъекта, ТипСодержимого)
	
	Если Не ПустаяСтрока(ТипСодержимого) Тогда
		Возврат ТипСодержимого;
	КонецЕсли;
	
	Возврат ТипСодержимогоПоИмениФайла(КлючОбъекта);
	
КонецФункции

Функция ТипСодержимогоПоИмениФайла(ИмяФайла)
	
	Расширение = НРег(РасширениеФайла(ИмяФайла));
	Возврат ТипСодержимогоПоРасширению(Расширение);
	
КонецФункции

Функция ТипСодержимогоПоРасширению(Расширение)
	
	Если Расширение = "jpg" Или Расширение = "jpeg" Тогда
		Возврат "image/jpeg";
	ИначеЕсли Расширение = "png" Тогда
		Возврат "image/png";
	ИначеЕсли Расширение = "gif" Тогда
		Возврат "image/gif";
	ИначеЕсли Расширение = "webp" Тогда
		Возврат "image/webp";
	ИначеЕсли Расширение = "svg" Тогда
		Возврат "image/svg+xml";
	ИначеЕсли Расширение = "pdf" Тогда
		Возврат "application/pdf";
	ИначеЕсли Расширение = "json" Тогда
		Возврат "application/json";
	ИначеЕсли Расширение = "xml" Тогда
		Возврат "application/xml";
	ИначеЕсли Расширение = "txt" Тогда
		Возврат "text/plain";
	ИначеЕсли Расширение = "csv" Тогда
		Возврат "text/csv";
	ИначеЕсли Расширение = "html" Или Расширение = "htm" Тогда
		Возврат "text/html";
	ИначеЕсли Расширение = "xls" Тогда
		Возврат "application/vnd.ms-excel";
	ИначеЕсли Расширение = "xlsx" Тогда
		Возврат "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
	ИначеЕсли Расширение = "doc" Тогда
		Возврат "application/msword";
	ИначеЕсли Расширение = "docx" Тогда
		Возврат "application/vnd.openxmlformats-officedocument.wordprocessingml.document";
	КонецЕсли;
	
	Возврат "application/octet-stream";
	
КонецФункции

Функция ЗначениеЗаголовка(Заголовки, ИмяЗаголовка)
	
	НормализованноеИмя = НРег(ИмяЗаголовка);
	
	Для Каждого Заголовок Из Заголовки Цикл
		Если НРег(Заголовок.Ключ) = НормализованноеИмя Тогда
			Возврат Заголовок.Значение;
		КонецЕсли;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

Функция ЧислоИзСтроки(Значение)
	
	СтроковоеЗначение = СокрЛП(Значение);
	
	Если ПустаяСтрока(СтроковоеЗначение) Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат Число(СтроковоеЗначение);
	
КонецФункции

Функция ОчиститьETag(Значение)
	
	Возврат СтрЗаменить(Значение, """", "");
	
КонецФункции

Функция РасширениеФайла(ИмяФайла)
	
	Позиция = СтрДлина(ИмяФайла);
	
	Пока Позиция > 0 Цикл
		СимволИмени = Сред(ИмяФайла, Позиция, 1);
		
		Если СимволИмени = "." Тогда
			Возврат Сред(ИмяФайла, Позиция + 1);
		ИначеЕсли СимволИмени = "/" Или СимволИмени = "\" Тогда
			Возврат "";
		КонецЕсли;
		
		Позиция = Позиция - 1;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

Процедура ПодписатьЗапрос(ПараметрыПодключения, Метод, КаноническийURI, КаноническийQueryString, Заголовки, ТелоЗапроса)
	
	ДатаВремяAWS = Заголовки["x-amz-date"];
	ДатаAWS = Лев(ДатаВремяAWS, 8);
	
	КаноническиеЗаголовки = КаноническиеЗаголовки(Заголовки);
	ПодписываемыеЗаголовки = ПодписываемыеЗаголовки(Заголовки);
	
	КаноническийЗапрос = Метод + Символы.ПС
		+ КаноническийURI + Символы.ПС
		+ КаноническийQueryString + Символы.ПС
		+ КаноническиеЗаголовки + Символы.ПС
		+ ПодписываемыеЗаголовки + Символы.ПС
		+ SHA256Hex(ТелоЗапроса);
	
	ОбластьПодписи = ДатаAWS + "/" + ПараметрыПодключения.Region + "/s3/aws4_request";
	СтрокаКПодписи = "AWS4-HMAC-SHA256" + Символы.ПС
		+ ДатаВремяAWS + Символы.ПС
		+ ОбластьПодписи + Символы.ПС
		+ SHA256Hex(СтрокаВДвоичныеДанные(КаноническийЗапрос));
	
	КлючПодписи = КлючПодписиAWS(ПараметрыПодключения.SecretAccessKey, ДатаAWS, ПараметрыПодключения.Region);
	Подпись = HMACSHA256Hex(КлючПодписи, СтрокаВДвоичныеДанные(СтрокаКПодписи));
	
	Авторизация = "AWS4-HMAC-SHA256 Credential=" + ПараметрыПодключения.AccessKeyId + "/" + ОбластьПодписи
		+ ", SignedHeaders=" + ПодписываемыеЗаголовки
		+ ", Signature=" + Подпись;
	
	Заголовки.Вставить("authorization", Авторизация);
	
КонецПроцедуры

Функция ПолучитьВременнуюСсылку(ПараметрыПодключения, Метод, КлючОбъекта, СрокДействияСек)
	
	ПроверитьПараметрыПодключения(ПараметрыПодключения);
	ПроверитьСрокДействияВременнойСсылки(СрокДействияСек);
	
	ПараметрыЗапроса = ПодготовитьПараметрыЗапроса(ПараметрыПодключения, КлючОбъекта);
	ДатаВремяAWS = ДатаAWS(ТекущаяУниверсальнаяДата());
	ДатаAWS = Лев(ДатаВремяAWS, 8);
	ОбластьПодписи = ДатаAWS + "/" + ПараметрыПодключения.Region + "/s3/aws4_request";
	
	ПараметрыQuery = Новый Соответствие;
	ПараметрыQuery.Вставить("X-Amz-Algorithm", "AWS4-HMAC-SHA256");
	ПараметрыQuery.Вставить("X-Amz-Credential", ПараметрыПодключения.AccessKeyId + "/" + ОбластьПодписи);
	ПараметрыQuery.Вставить("X-Amz-Date", ДатаВремяAWS);
	ПараметрыQuery.Вставить("X-Amz-Expires", Формат(СрокДействияСек, "ЧГ=0"));
	ПараметрыQuery.Вставить("X-Amz-SignedHeaders", "host");
	
	КаноническийQueryString = КаноническаяСтрокаЗапроса(ПараметрыQuery);
	КаноническийЗапрос = Метод + Символы.ПС
		+ ПараметрыЗапроса.КаноническийURI + Символы.ПС
		+ КаноническийQueryString + Символы.ПС
		+ "host:" + ПараметрыЗапроса.ХостСПортом + Символы.ПС + Символы.ПС
		+ "host" + Символы.ПС
		+ "UNSIGNED-PAYLOAD";
	
	СтрокаКПодписи = "AWS4-HMAC-SHA256" + Символы.ПС
		+ ДатаВремяAWS + Символы.ПС
		+ ОбластьПодписи + Символы.ПС
		+ SHA256Hex(СтрокаВДвоичныеДанные(КаноническийЗапрос));
	
	КлючПодписи = КлючПодписиAWS(ПараметрыПодключения.SecretAccessKey, ДатаAWS, ПараметрыПодключения.Region);
	Подпись = HMACSHA256Hex(КлючПодписи, СтрокаВДвоичныеДанные(СтрокаКПодписи));
	
	Возврат ПараметрыЗапроса.Схема + "://" + ПараметрыЗапроса.ХостСПортом
		+ ПутьЗапросаСQuery(
			ПараметрыЗапроса.ПутьЗапроса,
			КаноническийQueryString + "&X-Amz-Signature=" + Подпись);
	
КонецФункции

Процедура ПроверитьСрокДействияВременнойСсылки(СрокДействияСек)
	
	Если СрокДействияСек < 1 Или СрокДействияСек > 604800 Тогда
		ВызватьИсключение "S3: срок действия временной ссылки должен быть от 1 до 604800 секунд.";
	КонецЕсли;
	
КонецПроцедуры

Функция КаноническаяСтрокаЗапроса(ПараметрыQuery)
	
	Части = Новый Массив;
	
	Для Каждого ПараметрQuery Из ПараметрыQuery Цикл
		Части.Добавить(КодироватьКомпонентURI(ПараметрQuery.Ключ)
			+ "=" + КодироватьКомпонентURI(Строка(ПараметрQuery.Значение)));
	КонецЦикла;
	
	ОтсортироватьСтроковыйМассив(Части);
	Возврат СтрСоединить(Части, "&");
	
КонецФункции

Функция ПутьЗапросаСQuery(ПутьЗапроса, QueryString)
	
	Если ПустаяСтрока(QueryString) Тогда
		Возврат ПутьЗапроса;
	КонецЕсли;
	
	Возврат ПутьЗапроса + "?" + QueryString;
	
КонецФункции

Функция СоединениеS3(ПараметрыЗапроса, ПараметрыПодключения)
	
	Таймаут = ПолучитьСвойствоСПараметромПоУмолчанию(ПараметрыПодключения, "Таймаут", 30);
	ЗащищенноеСоединение = ЗащищенноеСоединениеS3(ПараметрыЗапроса);
	
	Возврат СоздатьHTTPСоединениеS3(
		ПараметрыЗапроса.Хост,
		ПараметрыЗапроса.Порт,
		Таймаут,
		ЗащищенноеСоединение);
	
КонецФункции

Функция ЗащищенноеСоединениеS3(ПараметрыЗапроса)
	
	Если ПараметрыЗапроса.Схема = "https" Тогда
		Возврат Новый ЗащищенноеСоединениеOpenSSL;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция СоздатьHTTPСоединениеS3(Хост, Порт, Таймаут, ЗащищенноеСоединение)
	
	Возврат Новый HTTPСоединение(Хост, Порт, , , , Таймаут, ЗащищенноеСоединение);
	
КонецФункции

Процедура ПроверитьОтвет(Ответ, ОписаниеОперации, ОжидаемыйКод)
	
	Если Ответ.КодСостояния = ОжидаемыйКод Тогда
		Возврат;
	КонецЕсли;
	
	ТелоОтвета = ТелоОтветаКакСтрока(Ответ);
	ОшибкаS3 = ИнформацияОбОшибкеS3(Ответ.КодСостояния, ТелоОтвета);
	ТекстОшибки = ПредставлениеОшибкиS3(ОписаниеОперации, ОшибкаS3);
	
	ЗаписьЖурналаРегистрации("S3Клиент", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
	
	ВызватьИсключение ТекстОшибки;
	
КонецПроцедуры

Функция ТелоОтветаКакСтрока(Ответ)
	
	Попытка
		Возврат Ответ.ПолучитьТелоКакСтроку();
	Исключение
		ПричинаОшибки = ИнформацияОбОшибке();
		ТекстОшибки = "S3: не удалось прочитать тело HTTP-ответа. "
			+ ПодробноеПредставлениеОшибки(ПричинаОшибки);
		ЗаписьЖурналаРегистрации("S3Клиент", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
		ВызватьИсключение(ТекстОшибки, , , , ПричинаОшибки);
	КонецПопытки;
	
КонецФункции

Функция ИнформацияОбОшибкеS3(КодHTTP, ТелоОтвета)
	
	ОшибкаS3 = Новый Структура;
	ОшибкаS3.Вставить("КодHTTP", КодHTTP);
	ОшибкаS3.Вставить("КодS3", ЗначениеXMLТега(ТелоОтвета, "Code"));
	ОшибкаS3.Вставить("Сообщение", ЗначениеXMLТега(ТелоОтвета, "Message"));
	ОшибкаS3.Вставить("Ключ", ЗначениеXMLТега(ТелоОтвета, "Key"));
	ОшибкаS3.Вставить("Bucket", ЗначениеXMLТега(ТелоОтвета, "BucketName"));
	ОшибкаS3.Вставить("Resource", ЗначениеXMLТега(ТелоОтвета, "Resource"));
	ОшибкаS3.Вставить("RequestId", ЗначениеXMLТега(ТелоОтвета, "RequestId"));
	ОшибкаS3.Вставить("HostId", ЗначениеXMLТега(ТелоОтвета, "HostId"));
	ОшибкаS3.Вставить("ТелоОтвета", ТелоОтвета);
	Возврат ОшибкаS3;
	
КонецФункции

Функция ПредставлениеОшибкиS3(ОписаниеОперации, ОшибкаS3)
	
	Текст = "S3: ошибка " + ОписаниеОперации + ". HTTP " + Строка(ОшибкаS3.КодHTTP);
	
	Если Не ПустаяСтрока(ОшибкаS3.КодS3) Тогда
		Текст = Текст + ", Code=" + ОшибкаS3.КодS3;
	КонецЕсли;
	
	Если Не ПустаяСтрока(ОшибкаS3.Сообщение) Тогда
		Текст = Текст + ", Message=" + ОшибкаS3.Сообщение;
	КонецЕсли;
	
	Если Не ПустаяСтрока(ОшибкаS3.RequestId) Тогда
		Текст = Текст + ", RequestId=" + ОшибкаS3.RequestId;
	КонецЕсли;
	
	Если Не ПустаяСтрока(ОшибкаS3.ТелоОтвета) Тогда
		Текст = Текст + Символы.ПС + ОшибкаS3.ТелоОтвета;
	КонецЕсли;
	
	Возврат Текст;
	
КонецФункции

Функция ЗначениеXMLТега(ТекстXML, ИмяТега)
	
	ПозицияНачала = ПозицияНачалаXMLТега(ТекстXML, ИмяТега);
	
	Если ПозицияНачала = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	ПозицияЗакрытияОткрывающегоТега = ПозицияСтрокиСНачальнойПозиции(ТекстXML, ">", ПозицияНачала);
	Если ПозицияЗакрытияОткрывающегоТега = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	ЗакрывающийТег = "</" + ИмяТега + ">";
	ПозицияЗначения = ПозицияЗакрытияОткрывающегоТега + 1;
	ПозицияКонца = ПозицияСтрокиСНачальнойПозиции(ТекстXML, ЗакрывающийТег, ПозицияЗначения);
	
	Если ПозицияКонца = 0 Тогда
		ПозицияКонца = ПозицияЗакрывающегоXMLТега(ТекстXML, ИмяТега, ПозицияЗначения);
	КонецЕсли;
	
	Если ПозицияКонца = 0 Или ПозицияКонца <= ПозицияЗначения Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Сред(ТекстXML, ПозицияЗначения, ПозицияКонца - ПозицияЗначения);
	
КонецФункции

Функция ПозицияНачалаXMLТега(ТекстXML, ИмяТега, ПозицияПоиска = 1)
	
	Пока Истина Цикл
		ПозицияНачала = ПозицияСтрокиСНачальнойПозиции(ТекстXML, "<", ПозицияПоиска);
		Если ПозицияНачала = 0 Тогда
			Возврат 0;
		КонецЕсли;
		
		ПозицияКонца = ПозицияСтрокиСНачальнойПозиции(ТекстXML, ">", ПозицияНачала);
		Если ПозицияКонца = 0 Тогда
			Возврат 0;
		КонецЕсли;
		
		ОткрывающийТег = Сред(ТекстXML, ПозицияНачала + 1, ПозицияКонца - ПозицияНачала - 1);
		Если Лев(ОткрывающийТег, 1) <> "/" И Лев(ОткрывающийТег, 1) <> "?"
			И Лев(ОткрывающийТег, 1) <> "!" И ЛокальноеИмяXMLТега(ОткрывающийТег) = ИмяТега Тогда
			Возврат ПозицияНачала;
		КонецЕсли;
		
		ПозицияПоиска = ПозицияКонца + 1;
	КонецЦикла;
	
КонецФункции

Функция ПозицияЗакрывающегоXMLТега(ТекстXML, ИмяТега, ПозицияПоиска)
	
	Пока Истина Цикл
		ПозицияНачала = ПозицияСтрокиСНачальнойПозиции(ТекстXML, "</", ПозицияПоиска);
		Если ПозицияНачала = 0 Тогда
			Возврат 0;
		КонецЕсли;
		
		ПозицияКонца = ПозицияСтрокиСНачальнойПозиции(ТекстXML, ">", ПозицияНачала);
		Если ПозицияКонца = 0 Тогда
			Возврат 0;
		КонецЕсли;
		
		ЗакрывающийТег = Сред(ТекстXML, ПозицияНачала + 2, ПозицияКонца - ПозицияНачала - 2);
		Если ЛокальноеИмяXMLТега(ЗакрывающийТег) = ИмяТега Тогда
			Возврат ПозицияНачала;
		КонецЕсли;
		
		ПозицияПоиска = ПозицияКонца + 1;
	КонецЦикла;
	
КонецФункции

Функция ПозицияСтрокиСНачальнойПозиции(Текст, Подстрока, НачальнаяПозиция)
	
	Если НачальнаяПозиция < 1 Или НачальнаяПозиция > СтрДлина(Текст) Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат СтрНайти(Текст, Подстрока, НаправлениеПоиска.СНачала, НачальнаяПозиция);
	
КонецФункции

Функция ЛокальноеИмяXMLТега(ТекстТега)
	
	Имя = СокрЛП(ТекстТега);
	ПозицияПробела = СтрНайти(Имя, " ");
	Если ПозицияПробела > 0 Тогда
		Имя = Лев(Имя, ПозицияПробела - 1);
	КонецЕсли;
	
	Если Прав(Имя, 1) = "/" Тогда
		Имя = Лев(Имя, СтрДлина(Имя) - 1);
	КонецЕсли;
	
	ПозицияПространстваИмен = СтрНайти(Имя, ":");
	Если ПозицияПространстваИмен > 0 Тогда
		Имя = Сред(Имя, ПозицияПространстваИмен + 1);
	КонецЕсли;
	
	Возврат Имя;
	
КонецФункции

Функция РазобратьОтветСпискаОбъектов(ТелоОтвета)
	
	Результат = Новый Структура;
	Результат.Вставить("Объекты", Новый Массив);
	Результат.Вставить("ЕстьЕще", НРег(ЗначениеS3XMLТега(ТелоОтвета, "IsTruncated")) = "true");
	Результат.Вставить("СледующийТокен", ДекодироватьXMLСтроку(ЗначениеS3XMLТега(ТелоОтвета, "NextContinuationToken")));
	
	БлокиОбъектов = БлокиS3XMLТега(ТелоОтвета, "Contents");
	Для Каждого БлокОбъекта Из БлокиОбъектов Цикл
		Объект = Новый Структура;
		Объект.Вставить("Ключ", ДекодироватьXMLСтроку(ЗначениеS3XMLТега(БлокОбъекта, "Key")));
		Объект.Вставить("ДатаИзменения", ЗначениеS3XMLТега(БлокОбъекта, "LastModified"));
		Объект.Вставить("ETag", ОчиститьETag(ЗначениеS3XMLТега(БлокОбъекта, "ETag")));
		Объект.Вставить("Размер", ЧислоИзСтроки(ЗначениеS3XMLТега(БлокОбъекта, "Size")));
		Объект.Вставить("КлассХранения", ЗначениеS3XMLТега(БлокОбъекта, "StorageClass"));
		Результат.Объекты.Добавить(Объект);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЗначениеS3XMLТега(ТекстXML, ИмяТега)
	
	ОткрывающийТег = "<" + ИмяТега + ">";
	ЗакрывающийТег = "</" + ИмяТега + ">";
	
	ПозицияНачала = СтрНайти(ТекстXML, ОткрывающийТег);
	Если ПозицияНачала = 0 Тогда
		Возврат ЗначениеXMLТега(ТекстXML, ИмяТега);
	КонецЕсли;
	
	ПозицияЗначения = ПозицияНачала + СтрДлина(ОткрывающийТег);
	ТекстПослеОткрывающегоТега = Сред(ТекстXML, ПозицияЗначения);
	ПозицияКонца = СтрНайти(ТекстПослеОткрывающегоТега, ЗакрывающийТег);
	Если ПозицияКонца = 0 Тогда
		Возврат ЗначениеXMLТега(ТекстXML, ИмяТега);
	КонецЕсли;
	
	Возврат Лев(ТекстПослеОткрывающегоТега, ПозицияКонца - 1);
	
КонецФункции

Функция БлокиS3XMLТега(ТекстXML, ИмяТега)
	
	Блоки = Новый Массив;
	ОткрывающийТег = "<" + ИмяТега + ">";
	ЗакрывающийТег = "</" + ИмяТега + ">";
	ПозицияПоиска = 1;
	
	Пока Истина Цикл
		ТекстПоиска = Сред(ТекстXML, ПозицияПоиска);
		ПозицияНачалаВТекстеПоиска = СтрНайти(ТекстПоиска, ОткрывающийТег);
		Если ПозицияНачалаВТекстеПоиска = 0 Тогда
			Прервать;
		КонецЕсли;
		
		ПозицияНачала = ПозицияПоиска + ПозицияНачалаВТекстеПоиска - 1;
		ПозицияСодержимого = ПозицияНачала + СтрДлина(ОткрывающийТег);
		ТекстПослеОткрывающегоТега = Сред(ТекстXML, ПозицияСодержимого);
		ПозицияКонцаВТекстеПослеОткрывающегоТега = СтрНайти(ТекстПослеОткрывающегоТега, ЗакрывающийТег);
		
		Если ПозицияКонцаВТекстеПослеОткрывающегоТега = 0 Тогда
			Прервать;
		КонецЕсли;
		
		ПозицияПослеТега = ПозицияСодержимого
			+ ПозицияКонцаВТекстеПослеОткрывающегоТега
			+ СтрДлина(ЗакрывающийТег)
			- 1;
		
		Блоки.Добавить(Сред(ТекстXML, ПозицияНачала, ПозицияПослеТега - ПозицияНачала));
		ПозицияПоиска = ПозицияПослеТега;
	КонецЦикла;
	
	Если Блоки.Количество() = 0 Тогда
		Возврат БлокиXMLТега(ТекстXML, ИмяТега);
	КонецЕсли;
	
	Возврат Блоки;
	
КонецФункции

Функция БлокиXMLТега(ТекстXML, ИмяТега)
	
	Блоки = Новый Массив;
	ПозицияПоиска = 1;
	
	Пока Истина Цикл
		ПозицияНачала = ПозицияНачалаXMLТега(ТекстXML, ИмяТега, ПозицияПоиска);
		Если ПозицияНачала = 0 Тогда
			Прервать;
		КонецЕсли;
		
		ПозицияКонца = ПозицияЗакрывающегоXMLТега(ТекстXML, ИмяТега, ПозицияНачала);
		Если ПозицияКонца = 0 Тогда
			Прервать;
		КонецЕсли;
		
		ПозицияЗакрытияТега = ПозицияСтрокиСНачальнойПозиции(ТекстXML, ">", ПозицияКонца);
		Если ПозицияЗакрытияТега = 0 Тогда
			Прервать;
		КонецЕсли;
		
		ПозицияПослеТега = ПозицияЗакрытияТега + 1;
		Блоки.Добавить(Сред(ТекстXML, ПозицияНачала, ПозицияПослеТега - ПозицияНачала));
		ПозицияПоиска = ПозицияПослеТега;
	КонецЦикла;
	
	Возврат Блоки;
	
КонецФункции

Функция ДекодироватьXMLСтроку(Значение)
	
	Результат = Строка(Значение);
	Результат = СтрЗаменить(Результат, "&lt;", "<");
	Результат = СтрЗаменить(Результат, "&gt;", ">");
	Результат = СтрЗаменить(Результат, "&quot;", """");
	Результат = СтрЗаменить(Результат, "&apos;", "'");
	Результат = СтрЗаменить(Результат, "&amp;", "&");
	Возврат Результат;
	
КонецФункции

Функция КлючПодписиAWS(SecretAccessKey, ДатаAWS, Region)
	
	КлючДата = HMACSHA256(СтрокаВДвоичныеДанные("AWS4" + SecretAccessKey), СтрокаВДвоичныеДанные(ДатаAWS));
	КлючРегион = HMACSHA256(КлючДата, СтрокаВДвоичныеДанные(Region));
	КлючСервис = HMACSHA256(КлючРегион, СтрокаВДвоичныеДанные("s3"));
	Возврат HMACSHA256(КлючСервис, СтрокаВДвоичныеДанные("aws4_request"));
	
КонецФункции

Функция HMACSHA256(Ключ, Данные)
	
	ДлинаБлока = 64;
	
	Если Ключ.Размер() > ДлинаБлока Тогда
		ХешированиеКлюча = Новый ХешированиеДанных(ХешФункция.SHA256);
		ХешированиеКлюча.Добавить(Ключ);
		КлючБуфер = ПолучитьБуферДвоичныхДанныхИзДвоичныхДанных(ХешированиеКлюча.ХешСумма);
	Иначе
		КлючБуфер = ПолучитьБуферДвоичныхДанныхИзДвоичныхДанных(Ключ);
	КонецЕсли;
	
	КлючБлока = Новый БуферДвоичныхДанных(ДлинаБлока);
	КлючБлока.Записать(0, КлючБуфер);
	
	ВнутреннийКлюч = КлючБлока.Скопировать();
	ВнешнийКлюч = КлючБлока;
	ВнутреннееВыравнивание = Новый БуферДвоичныхДанных(ДлинаБлока);
	ВнешнееВыравнивание = Новый БуферДвоичныхДанных(ДлинаБлока);
	
	Для Индекс = 0 По ДлинаБлока - 1 Цикл
		ВнутреннееВыравнивание.Установить(Индекс, 54);
		ВнешнееВыравнивание.Установить(Индекс, 92);
	КонецЦикла;
	
	ВнутреннийКлюч.ЗаписатьПобитовоеИсключительноеИли(0, ВнутреннееВыравнивание);
	ВнешнийКлюч.ЗаписатьПобитовоеИсключительноеИли(0, ВнешнееВыравнивание);
	
	ВнутреннееХеширование = Новый ХешированиеДанных(ХешФункция.SHA256);
	ВнутреннееХеширование.Добавить(ПолучитьДвоичныеДанныеИзБуфераДвоичныхДанных(ВнутреннийКлюч));
	ВнутреннееХеширование.Добавить(Данные);
	
	ВнешнееХеширование = Новый ХешированиеДанных(ХешФункция.SHA256);
	ВнешнееХеширование.Добавить(ПолучитьДвоичныеДанныеИзБуфераДвоичныхДанных(ВнешнийКлюч));
	ВнешнееХеширование.Добавить(ВнутреннееХеширование.ХешСумма);
	
	Возврат ВнешнееХеширование.ХешСумма;
	
КонецФункции

Функция HMACSHA256Hex(Ключ, Данные)
	
	Возврат ДвоичныеДанныеВHex(HMACSHA256(Ключ, Данные));
	
КонецФункции

Функция SHA256Hex(Данные)
	
	Хеширование = Новый ХешированиеДанных(ХешФункция.SHA256);
	Хеширование.Добавить(Данные);
	Возврат ДвоичныеДанныеВHex(Хеширование.ХешСумма);
	
КонецФункции

Функция ДвоичныеДанныеВHex(Данные)
	
	Возврат НРег(ПолучитьHexСтрокуИзДвоичныхДанных(Данные));
	
КонецФункции

Функция КаноническиеЗаголовки(Заголовки)
	
	Имена = ОтсортированныеИменаЗаголовков(Заголовки);
	Результат = "";
	
	Для Каждого Имя Из Имена Цикл
		Результат = Результат + НРег(Имя) + ":" + СократитьПробелы(Заголовки[Имя]) + Символы.ПС;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПодписываемыеЗаголовки(Заголовки)
	
	Имена = ОтсортированныеИменаЗаголовков(Заголовки);
	Возврат СтрСоединить(Имена, ";");
	
КонецФункции

Функция ОтсортированныеИменаЗаголовков(Заголовки)
	
	Имена = Новый Массив;
	Для Каждого Заголовок Из Заголовки Цикл
		Имена.Добавить(НРег(Заголовок.Ключ));
	КонецЦикла;
	
	ОтсортироватьСтроковыйМассив(Имена);
	Возврат Имена;
	
КонецФункции

Процедура ОтсортироватьСтроковыйМассив(МассивСтрок)
	
	Если МассивСтрок.Количество() < 2 Тогда
		Возврат;
	КонецЕсли;
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Значение");
	
	Для Каждого СтрокаМассива Из МассивСтрок Цикл
		СтрокаТаблицы = Таблица.Добавить();
		СтрокаТаблицы.Значение = СтрокаМассива;
	КонецЦикла;
	
	Таблица.Сортировать("Значение");
	МассивСтрок.Очистить();
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		МассивСтрок.Добавить(СтрокаТаблицы.Значение);
	КонецЦикла;
	
КонецПроцедуры

Функция РазобратьEndpoint(Endpoint, UseSSL)
	
	Адрес = СокрЛП(Endpoint);
	
	Если СтрНайти(Адрес, "://") = 0 Тогда
		Если UseSSL <> Ложь Тогда
			Адрес = "https://" + Адрес;
		Иначе
			Адрес = "http://" + Адрес;
		КонецЕсли;
	КонецЕсли;
	
	ПозицияСхемы = СтрНайти(Адрес, "://");
	Схема = НРег(Лев(Адрес, ПозицияСхемы - 1));
	БезСхемы = Сред(Адрес, ПозицияСхемы + 3);
	
	ПозицияПути = СтрНайти(БезСхемы, "/");
	Если ПозицияПути > 0 Тогда
		ХостСПортом = Лев(БезСхемы, ПозицияПути - 1);
	Иначе
		ХостСПортом = БезСхемы;
	КонецЕсли;
	
	Хост = ХостСПортом;
	Порт = ?(Схема = "https", 443, 80);
	ПозицияПорта = СтрНайти(ХостСПортом, ":");
	ПортВХосте = Ложь;
	
	Если ПозицияПорта > 0 Тогда
		Хост = Лев(ХостСПортом, ПозицияПорта - 1);
		Порт = Число(Сред(ХостСПортом, ПозицияПорта + 1));
		ПортВХосте = Истина;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Схема", Схема);
	Результат.Вставить("Хост", Хост);
	Результат.Вставить("Порт", Порт);
	Результат.Вставить("ХостСПортом", ХостСПортом);
	Результат.Вставить("ПортВХосте", ПортВХосте);
	Возврат Результат;
	
КонецФункции

Функция КодироватьПутьS3(КлючОбъекта)
	
	Части = СтрРазделить(КлючОбъекта, "/", Ложь);
	КодированныеЧасти = Новый Массив;
	
	Для Каждого Часть Из Части Цикл
		КодированныеЧасти.Добавить(КодироватьКомпонентURI(Часть));
	КонецЦикла;
	
	Возврат СтрСоединить(КодированныеЧасти, "/");
	
КонецФункции

Функция КодироватьКомпонентURI(Значение)
	
	Данные = СтрокаВДвоичныеДанные(Значение);
	Буфер = ПолучитьБуферДвоичныхДанныхИзДвоичныхДанных(Данные);
	Результат = "";
	
	Для Индекс = 0 По Буфер.Размер - 1 Цикл
		Байт = Буфер.Получить(Индекс);
		Если СимволРазрешенВURI(Байт) Тогда
			Результат = Результат + Символ(Байт);
		Иначе
			Результат = Результат + "%" + HexБайта(Байт);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция HexБайта(Байт)
	
	СимволыHex = "0123456789ABCDEF";
	СтаршийРазряд = Цел(Байт / 16);
	МладшийРазряд = Байт - СтаршийРазряд * 16;
	
	Возврат Сред(СимволыHex, СтаршийРазряд + 1, 1)
		+ Сред(СимволыHex, МладшийРазряд + 1, 1);
	
КонецФункции

Функция СимволРазрешенВURI(Байт)
	
	Возврат (Байт >= 48 И Байт <= 57)
		Или (Байт >= 65 И Байт <= 90)
		Или (Байт >= 97 И Байт <= 122)
		Или Байт = 45
		Или Байт = 46
		Или Байт = 95
		Или Байт = 126;
	
КонецФункции

Функция СтрокаВДвоичныеДанные(Значение)
	
	Возврат ПолучитьДвоичныеДанныеИзСтроки(Строка(Значение), КодировкаТекста.UTF8, Ложь);
	
КонецФункции

Функция ДатаAWS(Дата)
	
	Возврат ЧислоВСтрокуСВедущимиНулями(Год(Дата), 4)
		+ ЧислоВСтрокуСВедущимиНулями(Месяц(Дата), 2)
		+ ЧислоВСтрокуСВедущимиНулями(День(Дата), 2)
		+ "T"
		+ ЧислоВСтрокуСВедущимиНулями(Час(Дата), 2)
		+ ЧислоВСтрокуСВедущимиНулями(Минута(Дата), 2)
		+ ЧислоВСтрокуСВедущимиНулями(Секунда(Дата), 2)
		+ "Z";
	
КонецФункции

Функция ЧислоВСтрокуСВедущимиНулями(Значение, Длина)
	
	Возврат Прав("00000000000000000000" + Формат(Значение, "ЧГ=0"), Длина);
	
КонецФункции

Функция СократитьПробелы(Значение)
	
	Возврат СокрЛП(СтрЗаменить(Строка(Значение), Символы.Таб, " "));
	
КонецФункции

Функция ПолучитьСвойствоСПараметромПоУмолчанию(СтруктураПараметров, ИмяСвойства, ЗначениеПоУмолчанию)
	
	Если СтруктураПараметров.Свойство(ИмяСвойства) Тогда
		Возврат СтруктураПараметров[ИмяСвойства];
	КонецЕсли;
	
	Возврат ЗначениеПоУмолчанию;
	
КонецФункции

#КонецОбласти
