// Ручной интеграционный smoke-test для локального MinIO.
//
// Предусловия:
// 1. Запущен MinIO из docs/minio-s3client-dev.md.
// 2. Создан bucket s3client-dev.
// 3. Общий модуль s3Клиент загружен в тестовую информационную базу.
//
// Вызовите процедуру на сервере из временной обработки или консоли кода.

&НаСервере
Процедура ПроверитьS3КлиентСMinIO() Экспорт
	
	ПараметрыS3 = s3Клиент.ПараметрыПодключения(
		"http://localhost:9000",
		"us-east-1",
		"s3client-dev",
		"minioadmin",
		"minioadmin123",
		Истина,
		Ложь);
	
	КлючОбъекта = "smoke-tests/hello-from-1c.txt";
	ИсходнаяСтрока = "hello from 1C S3 client";
	ИсходныеДанные = ПолучитьДвоичныеДанныеИзСтроки(ИсходнаяСтрока, КодировкаТекста.UTF8, Ложь);
	
	РезультатЗагрузки = s3Клиент.ЗагрузитьДвоичныеДанные(
		ПараметрыS3,
		КлючОбъекта,
		ИсходныеДанные,
		"text/plain");
	
	Если РезультатЗагрузки.КодСостояния <> 200 Тогда
		ВызватьИсключение "Smoke: неожиданный код PUT " + Строка(РезультатЗагрузки.КодСостояния);
	КонецЕсли;
	
	Если Не s3Клиент.ОбъектСуществует(ПараметрыS3, КлючОбъекта) Тогда
		ВызватьИсключение "Smoke: объект не найден после загрузки.";
	КонецЕсли;
	
	Информация = s3Клиент.ПолучитьИнформациюОбОбъекте(ПараметрыS3, КлючОбъекта);
	Если Информация = Неопределено Или Информация.Размер <> ИсходныеДанные.Размер() Тогда
		ВызватьИсключение "Smoke: HEAD вернул неожиданный размер объекта.";
	КонецЕсли;
	
	ПрочитанныеДанные = s3Клиент.ПрочитатьДвоичныеДанные(ПараметрыS3, КлючОбъекта);
	ПрочитаннаяСтрока = ПолучитьСтрокуИзДвоичныхДанных(ПрочитанныеДанные, КодировкаТекста.UTF8);
	Если ПрочитаннаяСтрока <> ИсходнаяСтрока Тогда
		ВызватьИсключение "Smoke: прочитанные данные отличаются от исходных.";
	КонецЕсли;
	
	Список = s3Клиент.ПолучитьСписокОбъектов(ПараметрыS3, "smoke-tests/");
	Найден = Ложь;
	Для Каждого Объект Из Список.Объекты Цикл
		Если Объект.Ключ = КлючОбъекта Тогда
			Найден = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Не Найден Тогда
		ВызватьИсключение "Smoke: объект не найден в ListObjectsV2.";
	КонецЕсли;
	
	СсылкаНаЧтение = s3Клиент.ПолучитьВременнуюСсылкуНаЧтение(ПараметрыS3, КлючОбъекта, 300);
	Если ПустаяСтрока(СсылкаНаЧтение) Или СтрНайти(СсылкаНаЧтение, "X-Amz-Signature=") = 0 Тогда
		ВызватьИсключение "Smoke: временная ссылка на чтение не содержит подпись.";
	КонецЕсли;
	
	РезультатУдаления = s3Клиент.УдалитьОбъект(ПараметрыS3, КлючОбъекта);
	Если РезультатУдаления.КодСостояния <> 204 Тогда
		ВызватьИсключение "Smoke: неожиданный код DELETE " + Строка(РезультатУдаления.КодСостояния);
	КонецЕсли;
	
	Если s3Клиент.ОбъектСуществует(ПараметрыS3, КлючОбъекта) Тогда
		ВызватьИсключение "Smoke: объект найден после удаления.";
	КонецЕсли;
	
	Сообщить("Smoke OK: S3 клиент успешно прошел проверку MinIO.");
	
КонецПроцедуры
